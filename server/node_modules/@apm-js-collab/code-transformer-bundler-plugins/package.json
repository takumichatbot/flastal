{
    "name": "@apm-js-collab/code-transformer-bundler-plugins",
    "version": "0.5.0",
    "type": "module",
    "description": "A universal plugin that uses '@apm-js-collab/code-transformer' to instrument JavaScript code at build time",
    "keywords": [
        "rollup",
        "webpack",
        "vite",
        "esbuild",
        "bun",
        "turbopack",
        "loader",
        "plugin",
        "instrumentation",
        "apm",
        "tracing",
        "transform"
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/apm-js-collab/code-transformer-bundler-plugins"
    },
    "scripts": {
        "build": "vite build",
        "test": "vitest run"
    },
    "license": "MIT",
    "exports": {
        "./rollup": {
            "import": {
                "types": "./dist/esm/rollup.d.mts",
                "default": "./dist/esm/rollup.mjs"
            },
            "require": {
                "types": "./dist/cjs/rollup.d.cts",
                "default": "./dist/cjs/rollup.cjs"
            }
        },
        "./webpack": {
            "import": {
                "types": "./dist/esm/webpack.d.mts",
                "default": "./dist/esm/webpack.mjs"
            },
            "require": {
                "types": "./dist/cjs/webpack.d.cts",
                "default": "./dist/cjs/webpack.cjs"
            }
        },
        "./vite": {
            "import": {
                "types": "./dist/esm/vite.d.mts",
                "default": "./dist/esm/vite.mjs"
            },
            "require": {
                "types": "./dist/cjs/vite.d.cts",
                "default": "./dist/cjs/vite.cjs"
            }
        },
        "./esbuild": {
            "import": {
                "types": "./dist/esm/esbuild.d.mts",
                "default": "./dist/esm/esbuild.mjs"
            },
            "require": {
                "types": "./dist/cjs/esbuild.d.cts",
                "default": "./dist/cjs/esbuild.cjs"
            }
        },
        "./bun": {
            "types": "./dist/esm/bun.d.mts",
            "default": "./dist/esm/bun.mjs"
        },
        "./webpack-loader": {
            "types": "./dist/cjs/webpack-loader.d.cts",
            "default": "./dist/cjs/webpack-loader.cjs"
        }
    },
    "files": [
        "dist"
    ],
    "publishConfig": {
        "access": "public"
    },
    "dependencies": {
        "@apm-js-collab/code-transformer": "^0.15.0",
        "es-module-lexer": "^2.1.0",
        "module-details-from-path": "^1.0.4",
        "magic-string": "^0.30.21"
    },
    "devDependencies": {
        "@types/node": "^20.10.4",
        "@types/bun": "^1.3.14",
        "esbuild": "^0.28.1",
        "rollup": "^4.62.0",
        "tslib": "^2.6.2",
        "typescript": "^6.0.3",
        "unplugin-dts": "^1.0.1",
        "vite": "^8.0.16",
        "vitest": "^4.1.9",
        "webpack": "^5.107.2"
    },
    "engines": {
        "node": ">=18.0.0"
    },
    "volta": {
        "node": "22.17.0"
    }
}
