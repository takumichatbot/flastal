# ============================================================
# FLASTAL Server — 環境変数サンプル
# このファイルをコピーして .env を作成してください。
# cp .env.example .env
# ============================================================

# ============================================================
# 環境設定
# ============================================================
# アプリケーション実行環境（development / production / test）
NODE_ENV=development

# サーバーがリッスンするポート番号
PORT=3001

# ログ出力レベル（error / warn / info / debug）
# production では自動的に info になります。明示的に設定することで上書き可能。
LOG_LEVEL=info

# ============================================================
# データベース (PostgreSQL / Prisma)
# ============================================================
DATABASE_URL=postgresql://username:password@localhost:5432/flastal_db

# ============================================================
# 認証 (JWT)
# ============================================================
# 32文字以上のランダムな文字列を設定してください。
JWT_SECRET=your-super-secret-jwt-key-min-32-chars

# ============================================================
# フロントエンド URL
# ============================================================
# CORS 許可リストおよびメール内リンクのベース URL
FRONTEND_URL=http://localhost:3000

# メール内リンクや OG URL のベース URL（フロントエンドと同じで可）
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ============================================================
# Stripe 決済
# ============================================================
# シークレットキー（sk_test_... または sk_live_...）
STRIPE_SECRET_KEY=sk_test_...

# Stripe ダッシュボードで設定した Webhook の署名シークレット
STRIPE_WEBHOOK_SECRET=whsec_...

# ============================================================
# Apple アプリ内課金 (IAP)
# ============================================================
# App Store Connect > App内課金 > 「App用共有シークレット」で発行した値。
# レシート検証（verifyReceipt）の password に使用する。未設定だと iOS のポイント購入が検証で失敗する。
APPLE_IAP_SHARED_SECRET=

# ============================================================
# メール送信 (Resend)
# ============================================================
# Resend API キー（https://resend.com）
RESEND_API_KEY=re_...

# メール送信元アドレス（例: FLASTAL <noreply@flastal.com>）
EMAIL_FROM=FLASTAL <noreply@flastal.com>

# ============================================================
# AWS S3 ファイルアップロード
# ============================================================
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=ap-northeast-1

# S3 バケット名（どちらか一方を設定。AWS_S3_BUCKET_NAME が優先されます）
AWS_S3_BUCKET_NAME=flastal-uploads
AWS_BUCKET_NAME=flastal-uploads

# ============================================================
# Cloudinary 画像ホスティング（S3 の代替 / 補完として使用）
# ============================================================
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=000000000000000
CLOUDINARY_API_SECRET=...

# ============================================================
# Web Push 通知 (VAPID)
# ============================================================
# npx web-push generate-vapid-keys で生成できます。
# NEXT_PUBLIC_ 変数はサーバー・クライアント共通で使用します。
NEXT_PUBLIC_VAPID_PUBLIC_KEY=BG...
VAPID_PRIVATE_KEY=...

# ============================================================
# Google AI
# ============================================================
# Gemini API キー（画像解析・テキスト生成）
GEMINI_API_KEY=...

# GCP Vertex AI (Imagen 3) 設定
GOOGLE_CLOUD_PROJECT_ID=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=asia-northeast1
# サービスアカウント JSON ファイルへの絶対パス
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# ============================================================
# OpenAI
# ============================================================
OPENAI_API_KEY=sk-...

# ============================================================
# Typesense 全文検索
# ============================================================
TYPESENSE_HOST=localhost
TYPESENSE_PORT=8108
TYPESENSE_PROTOCOL=http
TYPESENSE_API_KEY=your-typesense-api-key

# ============================================================
# Redis / BullMQ メールキュー（オプション）
# ============================================================
# 設定しない場合、メールは fire-and-forget で直接送信されます。
REDIS_URL=redis://localhost:6379

# ============================================================
# Sentry エラー監視（オプション）
# ============================================================
# 設定しない場合、Sentry は無効化されます。
SENTRY_DSN=https://...@o000000.ingest.sentry.io/0000000

# ============================================================
# 管理者設定
# ============================================================
# 管理者として認識されるメールアドレス（カンマ区切りで複数指定可）
ADMIN_EMAILS=admin@flastal.com

# 管理者パスワード（管理機能が使用する場合）
ADMIN_PASSWORD=your_admin_password

# ============================================================
# ユーザー設定
# ============================================================
# 紹介コード使用時のボーナスポイント数（デフォルト: 200）
REFERRAL_BONUS_POINTS=200

# ============================================================
# 適格請求書（インボイス制度）
# ============================================================
# 本番環境では実際の登録番号（T + 13桁）に変更してください。
INVOICE_REGISTRATION_NUMBER=T0000000000000
