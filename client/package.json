{
  "name": "client",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "prisma:generate": "npx prisma generate --schema=../server/prisma/schema.prisma",
    "build": "next build",
    "start": "next start",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:headed": "playwright test --headed",
    "cap:build": "next build && npx cap sync",
    "cap:ios": "npm run cap:build && npx cap open ios",
    "cap:android": "npm run cap:build && npx cap open android",
    "cap:sync": "npx cap sync",
    "cap:dev:ios": "NODE_ENV=development npx cap run ios",
    "cap:build:prod": "NODE_ENV=production next build && npx cap sync",
    "cap:release:android": "npm run cap:build:prod && cd android && ./gradlew bundleRelease",
    "cap:release:ios": "npm run cap:build:prod && npx cap build ios --scheme App --configuration Release"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.946.0",
    "@aws-sdk/s3-request-presigner": "^3.946.0",
    "@capacitor/android": "^8.4.1",
    "@capacitor/cli": "^8.4.0",
    "@capacitor/core": "^8.4.0",
    "@capacitor/ios": "^8.4.0",
    "@capacitor/keyboard": "^8.0.3",
    "@capacitor/push-notifications": "^8.1.1",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@google/model-viewer": "^4.1.0",
    "@growthbook/growthbook": "^1.6.5",
    "@prisma/client": "^5.22.0",
    "@sentry/nextjs": "^10.59.0",
    "canvas-confetti": "^1.9.4",
    "jwt-decode": "^4.0.0",
    "next": "15.5.3",
    "next-pwa": "^5.6.0",
    "prisma": "^5.22.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-hook-form": "^7.65.0",
    "react-hot-toast": "^2.6.0",
    "react-icons": "^5.5.0",
    "react-markdown": "^10.1.0",
    "react-to-print": "^3.2.0",
    "recharts": "^3.8.1",
    "socket.io-client": "^4.8.1",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@eslint/eslintrc": "^3",
    "@playwright/test": "^1.61.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9",
    "eslint-config-next": "15.5.3",
    "tailwindcss": "^4",
    "typescript": "^6.0.3",
    "wait-on": "^9.0.10"
  }
}
